{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "ParsedMessage",
  "type": "object",
  "properties": {
    "subject": {
      "type": "string"
    },
    "from_email": {
      "type": "string"
    },
    "from_name": {
      "type": "string"
    },
    "to": {
      "type": "array"
    },
    "headers": {
      "type": "object"
    },
    "text": {
      "type": "string"
    },
    "html": {
      "type": "string"
    },
    "attachments": {
      "type": "array"
    },
    "images": {
      "type": "array"
    }
  }
}