{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "WebhookInfo",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "url": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "auth_key": {
      "type": "string"
    },
    "events": {
      "type": "array"
    },
    "created_at": {
      "type": "string"
    },
    "last_sent_at": {
      "type": "string"
    },
    "batches_sent": {
      "type": "integer"
    },
    "events_sent": {
      "type": "integer"
    },
    "last_error": {
      "type": "string"
    }
  }
}