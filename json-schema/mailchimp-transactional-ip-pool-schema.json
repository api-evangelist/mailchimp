{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IPPool",
  "type": "object",
  "description": "An IP pool grouping dedicated IPs.",
  "properties": {
    "name": {
      "type": "string",
      "description": "The pool name."
    },
    "created_at": {
      "type": "string",
      "description": "When the pool was created."
    },
    "ips": {
      "type": "array",
      "description": "The dedicated IPs in this pool."
    }
  }
}